// basic math
var x = 100;
var y = 37;
print x - y;
print x * y;

// conditionals
if (x > y) {
    print "x is greater";
} else {
    print "y is greater";
}

// while loop
var count = 3;
while (count > 0) {
    print count;
    count = count - 1;
}
print "done!";