// fibonacci sequence
fun fibonacci(n) {
    if (n <= 1) { return n; }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

// print first 10 fibonacci numbers
for (var i = 0; i < 10; i = i + 1) {
    print fibonacci(i);
}

